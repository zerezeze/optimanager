datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  OPERATOR
}

model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      UserRole @default(OPERATOR)
  clients   Client[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Client {
  id            String         @id @default(uuid())
  nome          String         @db.VarChar(255)
  endereco      String?        @db.VarChar(500)
  telefone      String?        @db.VarChar(20)
  userId        String         @map("user_id")
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  consultations Consultation[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([nome])
  @@index([telefone])
  @@index([userId])
  @@map("clients")
}

model Consultation {
  id            String   @id @default(uuid())
  clientId      String   @map("client_id")
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  olhoDireito   String?  @map("olho_direito") @db.VarChar(50)
  olhoEsquerdo  String?  @map("olho_esquerdo") @db.VarChar(50)

  // Olho Direito
  odEsferico    String?  @map("od_esferico") @db.VarChar(50)
  odCilindrico  String?  @map("od_cilindrico") @db.VarChar(50)
  odEixo        String?  @map("od_eixo") @db.VarChar(50)
  odDnp         String?  @map("od_dnp") @db.VarChar(50)
  odAltura      String?  @map("od_altura") @db.VarChar(50)
  
  // Olho Esquerdo
  oeEsferico    String?  @map("oe_esferico") @db.VarChar(50)
  oeCilindrico  String?  @map("oe_cilindrico") @db.VarChar(50)
  oeEixo        String?  @map("oe_eixo") @db.VarChar(50)
  oeDnp         String?  @map("oe_dnp") @db.VarChar(50)
  oeAltura      String?  @map("oe_altura") @db.VarChar(50)

  adicao        String?  @map("adicao") @db.VarChar(50)
  lentes        String?  @map("lentes") @db.VarChar(255)
  laboratorio   String?  @map("laboratorio") @db.VarChar(255)
  valor         Int // value in cents (e.g., 10000 = R$ 100,00)
  observacao    String?  @map("observacao") @db.Text
  data          DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([data])
  @@map("consultations")
}
